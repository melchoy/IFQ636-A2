{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@/components/ui/*": ["../../packages/ui/src/components/ui/*"],
      "@/hooks/*": ["../../packages/ui/src/hooks/*"],
      "@/lib/utils": ["../../packages/ui/src/lib/utils.ts"],
      "@otbt/types": ["../../packages/types/src/index.ts"],
      "@otbt/types/products": ["../../packages/types/src/products/index.ts"],
      "@otbt/ui": ["../../packages/ui/src/index.ts"],
      "@otbt/ui/globals.css": ["../../packages/ui/src/styles/globals.css"],
      "@otbt/web": ["../../packages/web/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": []
}
