{
  "name": "@otbt/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --include ../../packages/types/src --include .env src/server.ts",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "pnpm run test:typecheck && mocha --import=tsx \"test/**/*.test.ts\"",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.3.0",
    "@otbt/types": "workspace:*",
    "@paypal/paypal-server-sdk": "^2.4.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "dotenv": "^17.0.0",
    "fastify": "^5.8.5",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "nodemailer": "^8.0.10",
    "stripe": "^18.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^5.2.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.0",
    "chai": "^5.3.3",
    "esbuild": "^0.28.0",
    "mocha": "^11.7.5",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0"
  }
}
