{
  "name": "otbt",
  "version": "0.1.0",
  "private": true,
  "description": "Order of the Black Thorn online store application baseline.",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:nginx:up": "docker compose up -d nginx",
    "dev:nginx:down": "docker compose down",
    "dev:storefront": "pnpm --filter @otbt/storefront dev",
    "dev:admin": "pnpm --filter @otbt/admin dev",
    "dev:backend": "pnpm --filter @otbt/backend dev",
    "seed:admin": "pnpm --filter @otbt/backend exec tsx ../../seeds/scripts/admin.seed.ts",
    "seed:customers": "pnpm --filter @otbt/backend exec tsx ../../seeds/scripts/customers.seed.ts",
    "seed:products": "pnpm --filter @otbt/backend exec tsx ../../seeds/scripts/products.seed.ts",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm run typecheck && pnpm run build"
  }
}
